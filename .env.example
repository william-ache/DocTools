# =============================================================================
# CONFIGURACIÓN GENERAL DE LA APLICACIÓN
# =============================================================================
APP_NAME="Consultia"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Idioma y Localización
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

# =============================================================================
# CONFIGURACIÓN DE BASE DE DATOS (MYSQL)
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=doctools
DB_USERNAME=root
DB_PASSWORD=

# =============================================================================
# ASISTENTE VIRTUAL IA - DOCIA (LM STUDIO / OLLAMA)
# =============================================================================
# URL base del motor de IA local o remoto
OPENAI_BASE_URL=http://127.0.0.1:1234/v1
OPENAI_API_KEY=lm-studio
OPENAI_MODEL=qwen2.5-coder-1.5b-instruct

# Configuración visual y funcional del asistente
VITE_ASSISTANT_NAME="DocIA"
VITE_ASSISTANT_ENABLED=true

# =============================================================================
# DRIVERS DE SISTEMA Y SESIONES
# =============================================================================
# Driver para almacenamiento de sesiones y cache
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# Configuración de sesiones
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# =============================================================================
# CONFIGURACIÓN DE CORREO (MODO LOG PARA DESARROLLO)
# =============================================================================
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@consultia.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# FRONTEND - VITE
# =============================================================================
VITE_APP_NAME="${APP_NAME}"
